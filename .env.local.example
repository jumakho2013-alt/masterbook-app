# Шаблон для .env.local. Скопируй в `.env.local` и подставь реальные значения.
# `.env.local` гитигнорится, этот пример коммитится.

# Supabase — Project URL и anon public key из Dashboard → Settings → API.
# Никогда не используй service_role ключ в клиенте.
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_PUBLIC_KEY

# Dev-only: когда =1, приложение пропускает auth-редирект и засеивает
# демо-данные (клиенты, услуги, записи). Для визуальной проверки UI без
# настройки Supabase. В production ОБЯЗАТЕЛЬНО =0 или unset.
# На EAS production-сборках это принудительно "0" через eas.json env.
EXPO_PUBLIC_DEV_PREVIEW=0
