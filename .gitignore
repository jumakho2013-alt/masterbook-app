# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env
.env*.local

# typescript
*.tsbuildinfo

# generated native folders
# ios/ закоммичен намеренно: EAS-prebuild стабильно падал на Install pods,
# хотя локально поды встают (117 шт). Коммит готовой нативки → EAS пропускает
# свой prebuild и ставит поды по нашему Podfile.lock. android остаётся на CNG.
/android

# EAS local artefacts
.eas/
*.aab
*.apk
*.ipa
eas-*.log

# App Store / Google Play screenshots — собираются локально скриптом
# scripts/take-screenshots.sh и заливаются напрямую в Store Console.
# В репозиторий коммитить не надо (большие бинарники).
store-screenshots/

# Store credentials — never commit
google-service-account.json
AuthKey_*.p8
*.p12
*.mobileprovision
