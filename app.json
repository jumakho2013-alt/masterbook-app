{
  "expo": {
    "name": "MasterBook",
    "slug": "masterbook",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "masterbook",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.masterbook.app",
      "usesAppleSignIn": true,
      "associatedDomains": [],
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "UIBackgroundModes": [
          "remote-notification",
          "remote-notification"
        ],
        "NSPhotoLibraryUsageDescription": "Приложение использует доступ к фото для добавления фотографий работ клиентов",
        "NSCameraUsageDescription": "Приложение использует камеру для съёмки фотографий работ",
        "NSUserNotificationsUsageDescription": "Напоминания о предстоящих записях клиентов",
        "NSFaceIDUsageDescription": "Face ID защищает данные клиентов в приложении",
        "NSCalendarsUsageDescription": "Синхронизация записей с системным календарём — чтобы они появлялись в iPhone Calendar",
        "NSContactsUsageDescription": "MasterBook читает контакты только чтобы быстро добавить выбранных вами клиентов. Вся адресная книга никуда не отправляется.",
        "UIUserInterfaceStyle": "Automatic",
        "CFBundleLocalizations": [
          "ru",
          "en",
          "ru",
          "en"
        ],
        "CFBundleDevelopmentRegion": "ru"
      },
      "privacyManifests": {
        "NSPrivacyAccessedAPITypes": [
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryUserDefaults",
            "NSPrivacyAccessedAPITypeReasons": [
              "CA92.1"
            ]
          },
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryUserDefaults",
            "NSPrivacyAccessedAPITypeReasons": [
              "CA92.1"
            ]
          }
        ],
        "NSPrivacyCollectedDataTypes": [],
        "NSPrivacyTracking": false,
        "NSPrivacyTrackingDomains": []
      },
      "runtimeVersion": "1.0.0"
    },
    "android": {
      "package": "com.masterbook.app",
      "allowBackup": false,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#46384D"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.VIBRATE",
        "android.permission.SCHEDULE_EXACT_ALARM",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_CALENDAR",
        "android.permission.WRITE_CALENDAR",
        "android.permission.READ_CONTACTS",
        "android.permission.RECORD_AUDIO",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.VIBRATE",
        "android.permission.SCHEDULE_EXACT_ALARM",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_CALENDAR",
        "android.permission.WRITE_CALENDAR",
        "android.permission.READ_CONTACTS",
        "android.permission.RECORD_AUDIO",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT"
      ],
      "blockedPermissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.WRITE_CONTACTS",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.WRITE_CONTACTS",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ],
      "runtimeVersion": {
        "policy": "appVersion"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 340,
          "resizeMode": "contain",
          "backgroundColor": "#16121A"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Приложение использует доступ к фото для добавления фотографий работ",
          "cameraPermission": "Приложение использует камеру для съёмки фотографий работ"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#6B4E71",
          "defaultChannel": "reminders"
        }
      ],
      "expo-apple-authentication",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Приложение использует Face ID для защиты данных клиентов"
        }
      ],
      "expo-secure-store",
      "expo-localization",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "a8d2581b-5a73-49a8-aabf-d2d046224247"
      },
      "router": {}
    },
    "updates": {
      "url": "https://u.expo.dev/a8d2581b-5a73-49a8-aabf-d2d046224247"
    }
  }
}
