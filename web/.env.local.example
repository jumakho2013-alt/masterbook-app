# Те же значения, что у мобильного приложения (.env.local в корне):
#   EXPO_PUBLIC_SUPABASE_URL  → NEXT_PUBLIC_SUPABASE_URL
#   EXPO_PUBLIC_SUPABASE_ANON_KEY → NEXT_PUBLIC_SUPABASE_ANON_KEY
# Анонимный ключ безопасен на фронте: RLS пускает читать только published-мастеров.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_PUBLIC_KEY
